# Corta — frontend environment
#
# Copy to `.env` (or `.env.local`) for local dev, and set the same variable
# in your host's dashboard (Vercel / Netlify / Cloudflare Pages) for prod.

# URL of the Socket.IO signaling server (the corta-signal deploy).
# - Build-time only: Vite inlines `import.meta.env.VITE_SIGNAL_URL` during
#   `vite build`, so changing it in production requires a REBUILD.
# - If unset, the app falls back to http://localhost:3001 (local dev).
# - In production this MUST be https:// — Socket.IO upgrades it to wss://.
#   An http:// value on an https:// site is blocked as mixed content.
VITE_SIGNAL_URL=http://localhost:3001
